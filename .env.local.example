# ─── Inquiry mailer (Resend) ────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys, then set it locally
# (this file is the template — copy to .env.local) and on Vercel
# (Settings → Environment Variables).
RESEND_API_KEY=re_REPLACE_ME_WITH_YOUR_KEY

# Inquiry submissions route to this business address. Defaults to
# info@sonasapphire.com; override only if a shared inbox is added later.
INQUIRY_TO=info@sonasapphire.com
INQUIRY_FROM=Sona Sapphire <onboarding@resend.dev>

# Optional, local/dev only. Unset by default. If set, a sandbox-blocked
# send (unverified Resend domain) reroutes to this address instead of
# just failing — only useful for testing with your own inbox. Never set
# this in production without telling whoever's inbox it points at.
# INQUIRY_DEV_FALLBACK=you@example.com

# ─── Site URL (SEO / canonical / sitemap) ───────────────────────────────────
# Canonical origin for metadata, robots.txt, sitemap.xml, and JSON-LD.
# Falls back to the Vercel preview URL if unset. Set this to the real
# production domain once one is live.
# NEXT_PUBLIC_SITE_URL=https://sonasapphire.com
